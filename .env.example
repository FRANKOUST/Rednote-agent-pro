XHS_APP_NAME=Xiaohongshu Content Platform
XHS_ENVIRONMENT=development
XHS_DATABASE_URL=sqlite:///./data/app.db
XHS_MEDIA_DIR=./data/media
XHS_TASK_MODE=inline
XHS_ALLOW_AUTO_PUBLISH=false
XHS_ALLOW_LIVE_PUBLISH=false
XHS_DEFAULT_PUBLISH_PROVIDER=mock
XHS_TEAM_SLUG=internal-team

XHS_DEFAULT_COLLECTOR_PROVIDER=scrapling_xhs
XHS_SCRAPLING_MODE=fixture
XHS_SCRAPLING_TIMEOUT_SECONDS=30
XHS_SCRAPLING_HEADLESS=true
XHS_SCRAPLING_NETWORK_IDLE=true
XHS_SCRAPLING_ADAPTIVE_SELECTORS=true
XHS_SCRAPLING_MAX_RETRIES=2
XHS_SCRAPLING_CONCURRENCY=1
XHS_SCRAPLING_USER_AGENT=
XHS_SCRAPLING_COOKIES_PATH=./data/scrapling/cookies.json
XHS_SCRAPLING_STORAGE_STATE_PATH=./data/scrapling/storage_state.json
XHS_SCRAPLING_KEYWORDS_FILE=./data/collector/keywords.txt
XHS_SCRAPLING_NOTE_IDS_FILE=./data/collector/note_ids.txt
XHS_SCRAPLING_FIXTURE_DIR=./fixtures/scrapling
XHS_ENABLE_REAL_COLLECTOR=false

XHS_DEFAULT_SYNC_PROVIDER=feishu_cli
XHS_FEISHU_CLI_BIN=lark-cli
XHS_FEISHU_CLI_AS=user
XHS_FEISHU_SYNC_MODE=base
XHS_FEISHU_BASE_TOKEN=
XHS_FEISHU_TABLE_ID=
XHS_FEISHU_SHEET_TOKEN=
XHS_FEISHU_SHEET_RANGE=
XHS_FEISHU_CLI_TIMEOUT_SECONDS=60
XHS_FEISHU_CLI_MAX_RETRIES=2
XHS_FEISHU_CLI_DRY_RUN=true
XHS_FEISHU_FIELD_MAPPING_PATH=./config/feishu_field_mapping.json
XHS_ENABLE_REAL_SYNC_PROVIDER=false

XHS_DEFAULT_MODEL_PROVIDER=custom_model_router
XHS_MODEL_API_KEY=
XHS_MODEL_BASE_URL=https://api.openai.com/v1
XHS_MODEL_NAME=gpt-4.1-mini
XHS_MODEL_TIMEOUT_SECONDS=60
XHS_MODEL_MAX_RETRIES=2
XHS_MODEL_TEMPERATURE=0.2
XHS_ENABLE_REAL_MODEL_PROVIDER=false

XHS_DEFAULT_IMAGE_PROVIDER=mock
XHS_IMAGE_MODEL_PROVIDER=mock
XHS_IMAGE_MODEL_API_KEY=
XHS_IMAGE_MODEL_BASE_URL=https://api.openai.com/v1
XHS_IMAGE_MODEL_NAME=gpt-image-1
XHS_IMAGE_MODEL_TIMEOUT_SECONDS=60
XHS_IMAGE_MODEL_MAX_RETRIES=2
XHS_ENABLE_REAL_IMAGE_PROVIDER=false

XHS_XHS_PUBLISH_API_BASE=
XHS_XHS_PUBLISH_API_TOKEN=
XHS_ENABLE_REAL_PUBLISH_PROVIDER=false

XHS_AUTH_ENABLED=false
XHS_OPERATOR_API_KEY=
XHS_VIEWER_API_KEY=
XHS_REVIEWER_API_KEY=
XHS_ADMIN_API_KEY=
XHS_REQUEST_ID_HEADER_NAME=X-Request-ID
XHS_WORKER_ADAPTER_KIND=subprocess
XHS_WORKER_QUEUE_DIR=./data/worker-queue
XHS_WORKER_DEAD_LETTER_DIR=./data/worker-dead-letter
XHS_WORKER_MAX_ATTEMPTS=3
